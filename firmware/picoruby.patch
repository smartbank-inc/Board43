diff --git a/mrbgems/picoruby-r2p2/ports/rp2040/main.c b/mrbgems/picoruby-r2p2/ports/rp2040/main.c
index 06b39985..468bac2e 100644
--- a/mrbgems/picoruby-r2p2/ports/rp2040/main.c
+++ b/mrbgems/picoruby-r2p2/ports/rp2040/main.c
@@ -101,10 +101,16 @@ gpio_init_safe(void)
   // --- LED (16) ---
   gpio_set_in_pull_down(16);
 
-  // --- SWITCH, ENCODER, ADC (17-29) ---
+  // --- SWITCH, ENCODER, ADC (17-29, except 25) ---
   for (int pin = 17; pin <= 29; pin++) {
+    if (pin == 25) continue; // reserved for status LED
     gpio_set_in_pull_down(pin);
   }
+
+  // Status LED (GPIO25, active-high): on while powered
+  gpio_init(25);
+  gpio_set_dir(25, GPIO_OUT);
+  gpio_put(25, 1);
 }
 
 int
