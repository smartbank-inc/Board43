loop do
  # Check the tilt sensor: if flipped, we'll rotate 180°
  acc = imu.read_all[:acceleration]
  flip = acc[0] < -0.5 if acc[0].abs > 0.5

  # Draw the picture
  {{HEIGHT}}.times do |y|
    dst_y = flip ? {{H_MINUS_1}} - y : y
    {{WIDTH}}.times do |x|
      dst_x = flip ? {{W_MINUS_1}} - x : x
      c = pattern[y][x]
      led.set_rgb(dst_y * {{WIDTH}} + dst_x, c[0], c[1], c[2])
    end
  end

  # Push the colors to the LEDs, then pause
  led.show
  sleep_ms delay_ms
end
