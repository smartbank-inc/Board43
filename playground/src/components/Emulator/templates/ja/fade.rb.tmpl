loop do
  # フェードイン：明るさを 1/10 から最大まで段階的に増加
  10.times do |step|
    acc = imu.read_all[:acceleration]
    flip = acc[0] < -0.5 if acc[0].abs > 0.5
    b = step + 1
    {{HEIGHT}}.times do |y|
      dst_y = flip ? {{H_MINUS_1}} - y : y
      {{WIDTH}}.times do |x|
        dst_x = flip ? {{W_MINUS_1}} - x : x
        c = pattern[y][x]
        led.set_rgb(dst_y * {{WIDTH}} + dst_x, c[0] * b / 10, c[1] * b / 10, c[2] * b / 10)
      end
    end
    led.show
    sleep_ms delay_ms
  end

  # フェードアウト：明るさを最大から最小まで段階的に減少
  10.times do |step|
    acc = imu.read_all[:acceleration]
    flip = acc[0] < -0.5 if acc[0].abs > 0.5
    b = 9 - step
    {{HEIGHT}}.times do |y|
      dst_y = flip ? {{H_MINUS_1}} - y : y
      {{WIDTH}}.times do |x|
        dst_x = flip ? {{W_MINUS_1}} - x : x
        c = pattern[y][x]
        led.set_rgb(dst_y * {{WIDTH}} + dst_x, c[0] * b / 10, c[1] * b / 10, c[2] * b / 10)
      end
    end
    led.show
    sleep_ms delay_ms
  end

  # 次のフェードインまでの暗転休止
  sleep_ms 1000
end
