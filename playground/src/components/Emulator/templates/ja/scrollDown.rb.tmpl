loop do
  # 1 サイクル：`offset` で絵を 1 フレームごとに 1 行ずつ前進
  {{HEIGHT}}.times do |offset|
    # 傾きセンサーをチェック：反転していたら 180° 回転
    acc = imu.read_all[:acceleration]
    flip = acc[0] < -0.5 if acc[0].abs > 0.5

    # `offset` の分だけ縦方向にずらして絵を描画
    {{HEIGHT}}.times do |y|
      src_y = (y - offset + {{HEIGHT}}) % {{HEIGHT}}
      dst_y = flip ? {{H_MINUS_1}} - y : y
      {{WIDTH}}.times do |x|
        dst_x = flip ? {{W_MINUS_1}} - x : x
        c = pattern[src_y][x]; led.set_rgb(dst_y * {{WIDTH}} + dst_x, c[0], c[1], c[2])
      end
    end
    led.show

    # サイクルの最初では元の絵を少し長めに表示
    if offset == 0
      sleep_ms 1000
    else
      sleep_ms delay_ms
    end
  end
end
